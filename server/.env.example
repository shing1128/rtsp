# RTSP 流媒体服务配置

# ==========================================
# 服务器基础配置
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# 摄像头配置 (JSON格式)
# ==========================================
# cameras 是一个数组，每个摄像头包含：
# - id: 摄像头唯一标识
# - name: 摄像头名称
# - rtspUrl: RTSP流地址
# - enabled: 是否启用
# - protocol: 传输协议 (tcp/udp)
CAMERAS=[
  {
    "id": "cam001",
    "name": "测试摄像头1",
    "rtspUrl": "rtsp://admin:password@192.168.1.100:554/stream1",
    "enabled": true,
    "protocol": "tcp"
  },
  {
    "id": "cam002",
    "name": "测试摄像头2",
    "rtspUrl": "rtsp://admin:password@192.168.1.101:554/stream1",
    "enabled": false,
    "protocol": "tcp"
  }
]

# ==========================================
# 流媒体参数配置
# ==========================================
# 输出分辨率 (如: 640x360, 1280x720, 1920x1080)
STREAM_WIDTH=1280
STREAM_HEIGHT=720

# 视频码率 (如: 1000k, 2000k, 4000k)
STREAM_BITRATE=2000k

# 视频帧率 (fps)
STREAM_FPS=25

# 视频编码格式 (libx264, h264_nvenc 等)
STREAM_CODEC=libx264

# 输出格式 (flv, mpegts, hls)
STREAM_FORMAT=flv

# HLS 分片时长 (秒)
HLS_TIME=2

# HLS 分片数量
HLS_LIST_SIZE=5

# ==========================================
# WebSocket 配置
# ==========================================
# WebSocket 端口 (留空则使用 PORT)
WS_PORT=

# 心跳检测间隔 (毫秒)
WS_HEARTBEAT_INTERVAL=30000

# 客户端超时时间 (毫秒)
WS_CLIENT_TIMEOUT=60000

# ==========================================
# FFmpeg 配置
# ==========================================
# FFmpeg 可执行文件路径 (留空则使用系统 PATH 中的 ffmpeg)
FFMPEG_PATH=

# 输入超时时间 (微秒)
FFMPEG_INPUT_TIMEOUT=5000000

# 最大重连次数
FFMPEG_MAX_RECONNECT=5

# 重连间隔 (毫秒)
FFMPEG_RECONNECT_INTERVAL=5000

# 分析时长 (微秒)
FFMPEG_ANALYZE_DURATION=1000000

# 探测大小 (字节)
FFMPEG_PROBE_SIZE=2048

# ==========================================
# 日志配置
# ==========================================
# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=./logs/app.log

# 日志文件最大大小 (MB)
LOG_MAX_SIZE=50

# 保留的日志文件数量
LOG_MAX_FILES=5

# ==========================================
# 安全配置
# ==========================================
# 允许的跨域来源 (逗号分隔，* 表示允许所有)
CORS_ORIGIN=*

# API 认证密钥 (留空则不启用认证)
API_SECRET_KEY=

# 请求速率限制 (每分钟请求数)
RATE_LIMIT=100
